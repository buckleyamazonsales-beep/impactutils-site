# Copy to `.env` for local `netlify dev`. Set the same keys in Netlify → Environment variables.
# cPanel / PHP hosting: copy api/lemon-secrets.example.php → api/lemon-secrets.php instead.
# Do not commit a real `.env`.

LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
# Use each product’s Variant id (Lemon dashboard), not the Product id.
LEMONSQUEEZY_VARIANT_PRO=1526790
LEMONSQUEEZY_VARIANT_FOUNDER=1526794

# Optional: "true" while your Lemon store is in test mode
LEMONSQUEEZY_TEST_MODE=

IMPACT_PUBLIC_SITE_URL=https://impactutils.com
